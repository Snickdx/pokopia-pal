# Firebase web app (Vite — exposed to the browser; still keep .env gitignored)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — Firestore seed script (npm run seed)
# FIREBASE_PROJECT_ID=pokopia-pal
# GOOGLE_APPLICATION_CREDENTIALS=./sa.json

# Copy to .env and fill from:
# Firebase Console → Project settings → Your apps → Web app
# Or: npx firebase apps:sdkconfig WEB --project pokopia-pal
